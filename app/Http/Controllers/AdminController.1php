    public function update_query_status($id)
    {
        $user = Auth::user();
        if($user){
            if($id){
                $query = Tickets::find($id);
                if($query->status == "Open"){
                    $query->status = "Closed";
                }
                else{
                    $query->status = "Open";
                }
                $query->save();
                return back()->with('status_changed','query status changed.');
            }
        }
        else{
            return redirect()->route('admin');
        }
    }


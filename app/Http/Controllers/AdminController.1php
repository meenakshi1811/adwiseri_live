        function job_id()
        {
            $ch = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ";
            $id = "";
            for($i=0; $i<8; $i++){
                $id = $id.$ch[rand(0, strlen($ch)-1)];
            }
            return $id;
        }
        $user = Auth::user();
        if(isset($request->id)){
            $country = Countries::find($request->country);
            $nationality = Countries::find($request->nationality);
